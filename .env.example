# ══════════════════════════════════════════════════════════════════════════════
#  REVIEWAPI — Variáveis de Ambiente
#  Copie este arquivo para .env e preencha os valores reais.
#  O arquivo .env NUNCA deve ser commitado no Git.
# ══════════════════════════════════════════════════════════════════════════════

# ── Banco de Dados (PostgreSQL) ───────────────────────────────────────────────
# Em Docker Compose: use "postgres" como hostname (nome do container)
# Em desenvolvimento local: troque "postgres" por "localhost"
DATABASE_URL="postgresql://postgres:postgres@postgres:5432/reviewdb?schema=public"

# ── Servidor ──────────────────────────────────────────────────────────────────
PORT=3000

# Segredo para assinar tokens JWT — use uma string longa e aleatória em produção
JWT_SECRET=your_super_secret_jwt_key_here

# ── RabbitMQ ──────────────────────────────────────────────────────────────────
# Em Docker Compose: use "rabbitmq" como hostname (nome do container)
# Em desenvolvimento local: troque "rabbitmq" por "localhost"
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672

# ── APIs de Catálogo (opcional — usa dados mockados se não configurado) ───────
# Filmes e Séries — cadastre-se em: https://www.themoviedb.org/settings/api
TMDB_API_KEY=your_tmdb_api_key_here

# Jogos — cadastre-se em: https://rawg.io/apidocs
RAWG_API_KEY=your_rawg_api_key_here

# ── Worker: E-mail via Resend (opcional) ──────────────────────────────────────
# Sem esta chave, o e-mail é apenas logado no console do worker (modo mock)
# Cadastro grátis em: https://resend.com
RESEND_API_KEY=your_resend_api_key_here

# ── Worker: Sugestões de IA via Gemini (opcional) ─────────────────────────────
# Sem esta chave, é exibida uma sugestão genérica no e-mail e no PDF
# Chave grátis em: https://aistudio.google.com (modelo gemini-2.5-flash)
GEMINI_API_KEY=your_gemini_api_key_here

# ── Frontend: Login com Google OAuth (opcional) ───────────────────────────────
# Sem esta chave, o botão "Entrar com Google" não aparece na tela de login
# Como obter:
#   1. Acesse https://console.cloud.google.com
#   2. APIs e Serviços → Credenciais → Criar credenciais → ID do cliente OAuth
#   3. Tipo: Aplicativo da Web
#   4. Origens JavaScript autorizadas: http://localhost
#   5. Copie o ID gerado (termina com .apps.googleusercontent.com)
VITE_GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# ── Deploy Railway (frontend → backend) ───────────────────────────────────────
# APENAS para Railway: URL pública do serviço backend gerada pelo Railway
# Exemplo: https://reviewapi-av3-backend-production.up.railway.app/graphql
# Em Docker local: deixe em branco (o nginx faz o proxy automaticamente)
VITE_API_URL=
